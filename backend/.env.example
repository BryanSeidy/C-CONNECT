# =============================================================================
# C-Connect — Laravel Backend .env template
# Copie ce fichier en .env et remplis les valeurs marquées <CHANGE_ME>
# =============================================================================

APP_NAME="C-Connect"
APP_ENV=local
APP_KEY=<CHANGE_ME: php artisan key:generate>
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Douala
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# URL du frontend Next.js — doit correspondre exactement (pas de slash final)
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ---------------------------------------------------------------------------
# Database — PostgreSQL
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cconnect
DB_USERNAME=<CHANGE_ME>
DB_PASSWORD=<CHANGE_ME>

# ---------------------------------------------------------------------------
# Session — OBLIGATOIRE : cookie pour le mode stateful Sanctum
# ---------------------------------------------------------------------------
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ---------------------------------------------------------------------------
# Cache / Queue
# ---------------------------------------------------------------------------
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Mail (désactivé en local)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@c-connect.cm"
MAIL_FROM_NAME="${APP_NAME}"
