+/**
+ * Dérive l'URL racine du backend depuis la baseURL de l'axios client.
+ * Si NEXT_PUBLIC_API_URL = 'http://localhost:8000/api', retourne
+ * 'http://localhost:8000' (sans /api).
+ */
+function getBackendRoot(): string {
+  const base = apiClient.defaults.baseURL ?? 'http://localhost:8000/api';
+  return base.replace(/\/api\/?$/, '');
+}
