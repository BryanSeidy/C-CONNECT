.timeline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  margin: 1.5rem 0;
  gap: 0.5rem;
}

.timeline > div {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
  min-width: 72px;
}

.icon {
  width: 22px;
  height: 22px;
  margin-bottom: 0.4rem;
  color: var(--text-muted);
}

.label {
  font-size: 0.75rem;
  color: var(--text-main);
  text-align: center;
  line-height: 1.3;
}

.connector {
  position: absolute;
  top: 0.65rem;
  left: 50%;
  height: 2px;
  width: 100%;
  background: var(--border-color);
  z-index: -1;
}

.completed .icon {
  color: var(--success);
}

.completed .label {
  color: var(--success);
  font-weight: 600;
}

.completed .connector {
  background: var(--success);
  opacity: 0.4;
}

.current .icon {
  color: var(--primary-color);
}

.current .label {
  color: var(--primary-color);
  font-weight: 600;
}

.pending .icon {
  color: var(--text-muted);
  opacity: 0.5;
}

.pending .label {
  color: var(--text-muted);
}

.exceptionBadge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8125rem;
  font-weight: 600;
  padding: 0.5rem 0.85rem;
  border-radius: var(--radius-sm);
}

.exceptionBadge[data-tone='cancelled'] {
  background: rgba(100, 116, 139, 0.1);
  color: var(--text-muted);
}

.exceptionBadge[data-tone='dispute'] {
  background: rgba(211, 47, 47, 0.08);
  color: var(--error);
}
